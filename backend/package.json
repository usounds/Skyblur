{
  "name": "skyblurapi",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env production --minify",
    "deploy:preview": "wrangler deploy --env preview --minify",
    "gen-lex": "lex-cli generate",
    "update": "pnpm dlx npm-check-updates -u --reject \"prisma,@prisma/client\" && pnpm install",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@atcute/atproto": "^3.1.11",
    "@atcute/client": "^4.2.1",
    "@atcute/identity-resolver": "^1.2.2",
    "@atcute/lexicons": "^1.3.0",
    "@atcute/oauth-crypto": "^0.1.0",
    "@atcute/oauth-node-client": "^1.1.0",
    "did-jwt": "^8.0.18",
    "did-resolver": "^5.0.1",
    "hono": "^4.12.17",
    "web-did-resolver": "^2.0.32"
  },
  "devDependencies": {
    "@atcute/bluesky": "^3.3.3",
    "@atcute/lex-cli": "^2.8.1",
    "@cloudflare/unenv-preset": "^2.16.1",
    "@cloudflare/workers-types": "^4.20260506.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "unenv": "2.0.0-rc.24",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.88.0"
  },
  "pnpm": {
    "overrides": {
      "flatted": "^3.4.2"
    }
  }
}