    "@atcute/oauth-node-client": "^2.0.0",
    "did-jwt": "^8.0.18",
    "did-resolver": "^5.0.1",
    "hono": "^4.12.26",
    "web-did-resolver": "^2.0.32"
  },
  "devDependencies": {
    "@atcute/bluesky": "^4.0.10",
    "@atcute/lex-cli": "^3.1.0",
    "@cloudflare/unenv-preset": "^2.16.1",
    "@cloudflare/workers-types": "^4.20260620.1",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "unenv": "2.0.0-rc.24",
