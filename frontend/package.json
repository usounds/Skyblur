{
  "name": "skyblur",
  "version": "0.4.1",
  "type": "module",
  "sideEffects": false,
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@atcute/time-ms",
      "aws-sdk",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "hono": "^4.11.7",
      "@modelcontextprotocol/sdk": "^1.26.0",
      "fast-xml-parser": "^5.7.1",
      "flatted": "^3.4.2",
      "zod": "^4.3.6",
      "@aws-sdk/client-dynamodb": "3.972.0",
      "@aws-sdk/dynamodb-codec": "3.972.0",
      "minimatch": "^10.2.1",
      "postcss": "^8.5.13",
      "@atcute/time-ms": "1.2.3",
      "@atcute/util-text": "1.1.1"
    }
  },
  "scripts": {
    "dev": "next dev -p 4500",
    "update": "pnpm dlx npm-check-updates -u -x eslint && pnpm install",
    "gen-lex": "lex-cli generate",
    "build": "next build",
    "start": "next start",
    "dev:aws": "pnpm dlx sst dev",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview --ip 192.168.1.130 --port 4500",
    "deploy:preview": "pnpm dlx sst deploy --stage preview",
    "deploy": "pnpm dlx sst deploy --stage production",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=webkit && node scripts/e2e-screen-coverage.mjs",
    "test:e2e:smoke": "playwright test --project=chromium --grep \"OAuth metadata points|public app pages render core unauthenticated content|home start button opens the console for logged-in users|/console renders logged-in dashboard\"",
    "test:e2e:browsers": "playwright test --project=chromium --project=firefox --project=webkit --grep \"OAuth metadata points|public app pages render core unauthenticated content|home start button opens the console for logged-in users|/console renders logged-in dashboard\"",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari --grep \"OAuth metadata points|public app pages render core unauthenticated content|home start button opens the console for logged-in users|/console renders logged-in dashboard\"",
    "test:e2e:all": "playwright test && node scripts/e2e-screen-coverage.mjs",
    "test:e2e:coverage": "node scripts/e2e-coverage-clean.mjs && E2E_COVERAGE=true playwright test --project=webkit --workers=1 && node scripts/e2e-screen-coverage.mjs && node scripts/e2e-coverage-report.mjs",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx"
  },
  "dependencies": {
    "@atcute/atproto": "^3.1.11",
    "@atcute/bluesky": "^3.3.3",
    "@atcute/client": "^4.2.1",
    "@atcute/identity-resolver": "^1.2.2",
    "@atcute/identity-resolver-node": "^1.0.3",
    "@atcute/lexicons": "^1.3.0",
    "@atcute/oauth-node-client": "^1.1.0",
    "@atcute/tid": "^1.1.2",
    "@atpassport/client": "^0.1.33",
    "@aws-sdk/client-dynamodb": "3.972.0",
    "@mantine/core": "^9.1.1",
    "@mantine/hooks": "^9.1.1",
    "@mantine/notifications": "^9.1.1",
    "@opennextjs/aws": "^3.10.4",
    "dompurify": "^3.4.2",
    "franc": "^6.2.0",
    "iso-639-3-to-1": "^1.0.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-content-loader": "^7.1.2",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-spinners": "^0.17.0",
    "sst": "^4.13.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@atcute/lex-cli": "^2.8.1",
    "@aws-sdk/client-lambda": "^3.1043.0",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "babel-loader": "^10.1.1",
    "babel-plugin-istanbul": "^8.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "tailwindcss": "^4.2.4",
    "tw-colors": "^3.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
